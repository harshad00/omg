<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="../../stylesheets/admin.css">
</head>

<body>

    <header>
        <h1> product data</h1>
    </header>
    <nav>
        <a href="../admin">Home</a>
        <a href="user-data">User Data</a>
        <a href="product-data">Product Data</a>
        <a href="addproduct">Add Product</a>
        <a href="order-details">Order Details</a>
        {{!-- <a href="user-data">User Data</a> --}}
    </nav>

    <main>
        <div id="page-data">
            <h1>Product List</h1>
            <div class="main-product-table">
            <table>
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Product Name</th>
                        <th>Product ID</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock Quantity</th>
                        <th>Gender</th>
                        <th>Images</th>
                        <th>Availability</th>
                        <th>Manufacturer</th>
                        {{!-- <th>Variants</th> --}}
                        <th>Delete Data</th>
                        <th>Update Data</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each product_data}}
                    <tr>
                        <td>{{@index}}</td>
                        <td>{{this.productname}}</td>
                        <td>{{this._id}}</td>
                        <td>{{this.description}}</td>
                        <td>{{this.category}}</td>
                        <td>{{this.price}}</td>
                        <td>{{this.stockQuantity}}</td>
                        <td>{{this.gender}}</td>
                        <td>
                            {{#each this.images}}
                            <img src="../../../images/uploads/{{this}}" alt="Product Image"
                                style="max-width: 50px; max-height: 50px; margin-right: 5px;">
                            {{/each}}
                        </td>
                        <td>{{this.availability}}</td>
                        <td>{{this.manufacturer}}</td>
                        {{!-- <td>
                            {{#each this.variants}}
                            <ul>
                                <li>Size: {{this.size}}</li>
                                <li>Color: {{this.color}}</li>
                                <li>Price: {{this.price}}</li>
                                <li>Stock Quantity: {{this.stockQuantity}}</li>
                                <li>Availability: {{this.availability}}</li>
                            </ul>
                            {{/each}}
                        </td> --}}

                        <!-- Inside the <td> for Update and Delete buttons -->
                        <!-- Inside the <td> for Update and Delete buttons -->
                        <td>
                            <a href="/admin-datas/delete-product/{{this._id}}" class="delete-link"
                                onclick="return confirm('Are you sure you want to delete this product?');">
                                Delete
                            </a>
                        </td>
                        <td>
                            <a href="/admin-datas/edit-product/{{this._id}}">Update</a>

                        </td>
                    </tr>
                    {{/each}}

                </tbody>
            </table>
            </div>
</div>
</main>

</body>

</html>