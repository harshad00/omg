        <a href="order-details">Order Details</a>
    </nav>
    <main class="add-product-table">
        <div id="page-data">
             <div class="container">
                <h2>Add Product</h2>
                <form id="productForm" action="/admin-datas/addproduct" method="post" enctype="multipart/form-data">
                    <label for="productname">Product Name:</label>
                    <input type="text" id="productName" name="productname" required>

                    <label for="description">Description:</label>
                    <textarea id="description" name="description" rows="4" required></textarea>

                     <!-- Category Label and Options -->
                     
                    <label>Category:</label>
                    <div class="category-options">
                        <input type="radio" id="optical" name="category" value="Optical" class="radio-btn" required>
                        <label for="optical">Optical</label>

                        <input type="radio" id="sunglasses" name="category" value="Sunglasses" class="radio-btn" required>
                        <label for="sunglasses">Sunglasses</label>

                        <input type="radio" id="watches" name="category" value="Watches" class="radio-btn" required>
                        <label for="watches">Watches</label>

                        <input type="radio" id="belts" name="category" value="Belts" class="radio-btn" required>
                        <label for="belts">Belts</label>

                        <input type="radio" id="wallets" name="category" value="Wallets" class="radio-btn" required>
                        <label for="wallets">Wallets</label>
                    </div>

                    <div class="gender_dev">
                        <!-- Inside the form, before the Category input -->
                        <!-- Checkbox inputs in your form -->
                        
                    <label for="price">Gender:</label>
                        <input type="checkbox" name="gender" value="male"> Male
                        <input type="checkbox" name="gender" value="female"> Female
                        <input type="checkbox" name="gender" value="other"> Other
                    </div>
                    <label for="price">Price:</label>
                    <input type="number" id="price" name="price" step="0.01" required>

                    <label for="stockQuantity">Stock Quantity:</label>
                    <input type="number" id="stockQuantity" name="stockQuantity" required>

                    <label for="images">Images (comma-separated URLs):</label>
                    <input type="file" id="images" name="images" accept="image/*"  required>

                    <label for="availability">Availability:</label>
                    <select id="availability" name="availability" required>
                        <option value="true">Available</option>
                        <option value="false">Not Available</option>
                    </select>
                    <label for="manufacturer">Manufacturer:</label>
                   <input type="text" id="manufacturer" name="manufacturer" required>
                 
